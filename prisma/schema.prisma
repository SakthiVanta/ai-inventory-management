generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AIProviderConfig {
  id               String   @id @default(cuid())
  userId           String
  name             String
  apiKey           String
  modelName        String
  maxContextTokens Int
  isActive         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  User             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model AuditLog {
  id                  String   @id @default(cuid())
  timestamp           DateTime @default(now())
  userEmail           String
  rawNLPrompt         String
  aiModelUsed         String
  cost                Float
  zodValidationResult String?
  transactionId       String
  actionType          String
  userId              String
  User                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([userId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  role        String
  content     String
  timestamp   DateTime    @default(now())
  ChatSession ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, timestamp])
}

model ChatSession {
  id          String        @id @default(cuid())
  userId      String
  title       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ChatMessage ChatMessage[]
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, updatedAt])
}

model ExternalDBConnection {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  url       String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InventoryItem {
  id        String   @id @default(cuid())
  userId    String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SchemaField {
  id         String   @id @default(cuid())
  userId     String
  name       String
  type       String
  isRequired Boolean  @default(false)
  badges     String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  User      User     @relation(fields: [userId], references: [id])
}

model TokenUsage {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  model     String
  cost      Float?
  action    String
  sessionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  company              String?
  password             String
  createdAt            DateTime              @default(now())
  AIProviderConfig     AIProviderConfig[]
  AuditLog             AuditLog[]
  ChatSession          ChatSession[]
  ExternalDBConnection ExternalDBConnection?
  InventoryItem        InventoryItem[]
  SchemaField          SchemaField[]
  Session              Session[]
  TokenUsage           TokenUsage[]
}
